  },
  "models": {
    "mode": "merge",
    "providers": {
      "google": {
        "baseUrl": "https://generativelanguage.googleapis.com/v1beta/openai",
        "apiKey": "${GEMINI_API_KEY}",
        "api": "google-generative-ai",
        "models": [
          {
            "id": "gemini-2.5-flash",
            "name": "Gemini 2.5 Flash",
            "reasoning": true,
            "input": [
              "text",
              "image",
              "audio",
              "video"
            ],
            "cost": {
              "input": 0.15,
              "output": 0.6,
              "cacheRead": 0.0375,
              "cacheWrite": 0.0375
            },
            "contextWindow": 1048576,
            "maxTokens": 65536
          }
        ]
      }
    }
  },
  "gateway": {
    "bind": "auto",
    "trustedProxies": [
      "any"
    ],
    "controlUi": {
      "allowedOrigins": [
        "*",
        "https://ai.elaiproject.site"
      ]
    },
    "auth": {
